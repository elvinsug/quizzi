<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_white"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="QUIZZI"
        android:textColor="@color/text_primary"
        android:textSize="36sp"
        android:textStyle="bold"
        android:letterSpacing="0.15"
        android:layout_marginBottom="48dp" />

    <!-- Segmented Control -->
    <com.google.android.material.tabs.TabLayout
        android:id="@+id/tabLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp"
        android:background="@drawable/bg_card_rounded"
        android:padding="4dp"
        style="@style/Widget.MaterialComponents.TabLayout" />

    <!-- PIN Entry Section -->
    <LinearLayout
        android:id="@+id/pinSection"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/enter_pin"
            android:textColor="@color/text_muted"
            android:textSize="15sp"
            android:layout_marginBottom="20dp" />

        <LinearLayout
            android:id="@+id/pinBoxContainer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginBottom="24dp">

            <EditText
                android:id="@+id/pinBox1"
                style="@style/PinBox"
                android:layout_width="48dp"
                android:layout_height="56dp"
                android:layout_marginEnd="8dp" />

            <EditText
                android:id="@+id/pinBox2"
                style="@style/PinBox"
                android:layout_width="48dp"
                android:layout_height="56dp"
                android:layout_marginEnd="8dp" />

            <EditText
                android:id="@+id/pinBox3"
                style="@style/PinBox"
                android:layout_width="48dp"
                android:layout_height="56dp"
                android:layout_marginEnd="8dp" />

            <EditText
                android:id="@+id/pinBox4"
                style="@style/PinBox"
                android:layout_width="48dp"
                android:layout_height="56dp"
                android:layout_marginEnd="8dp" />

            <EditText
                android:id="@+id/pinBox5"
                style="@style/PinBox"
                android:layout_width="48dp"
                android:layout_height="56dp"
                android:layout_marginEnd="8dp" />

            <EditText
                android:id="@+id/pinBox6"
                style="@style/PinBox"
                android:layout_width="48dp"
                android:layout_height="56dp" />
        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/enterBtn"
            android:layout_width="300dp"
            android:layout_height="wrap_content"
            android:text="@string/enter_btn"
            android:visibility="gone"
            style="@style/QuizziButton.Black" />

        <TextView
            android:id="@+id/errorText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/wrong_red"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_marginTop="12dp"
            android:visibility="gone" />
    </LinearLayout>

    <!-- QR Scanner Section -->
    <LinearLayout
        android:id="@+id/qrSection"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:visibility="gone">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/scanQrBtn"
            android:layout_width="300dp"
            android:layout_height="wrap_content"
            android:text="@string/scan_qr"
            android:layout_marginTop="24dp"
            style="@style/QuizziButton.Black" />
    </LinearLayout>

</LinearLayout>
