<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.Quizzi" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/black</item>
        <item name="colorPrimaryDark">@color/black</item>
        <item name="colorAccent">@color/black</item>
        <item name="android:statusBarColor">@color/bg_white</item>
        <item name="android:navigationBarColor">@color/bg_white</item>
        <item name="android:windowBackground">@color/bg_white</item>
        <item name="android:windowLightStatusBar">true</item>
    </style>

    <style name="QuizziButton" parent="Widget.MaterialComponents.Button">
        <item name="cornerRadius">12dp</item>
        <item name="android:textAllCaps">true</item>
        <item name="android:textSize">15sp</item>
        <item name="android:letterSpacing">0.04</item>
        <item name="android:paddingTop">14dp</item>
        <item name="android:paddingBottom">14dp</item>
    </style>

    <style name="QuizziButton.Black" parent="QuizziButton">
        <item name="backgroundTint">@color/black</item>
        <item name="android:textColor">@color/white</item>
    </style>

    <style name="QuizziButton.Outline" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="cornerRadius">12dp</item>
        <item name="android:textAllCaps">true</item>
        <item name="android:textSize">15sp</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="strokeColor">@color/text_light</item>
    </style>

    <!-- Legacy aliases -->
    <style name="QuizziButton.Green" parent="QuizziButton.Black" />
    <style name="QuizziButton.Purple" parent="QuizziButton.Black" />

    <style name="AnswerButton" parent="Widget.MaterialComponents.Button">
        <item name="cornerRadius">20dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:minHeight">80dp</item>
        <item name="elevation">4dp</item>
    </style>

    <style name="PinInput">
        <item name="android:textSize">42sp</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textStyle">bold</item>
        <item name="android:gravity">center</item>
        <item name="android:letterSpacing">0.3</item>
        <item name="android:background">@android:color/transparent</item>
        <item name="android:inputType">number</item>
        <item name="android:maxLength">6</item>
    </style>

    <style name="PinBox">
        <item name="android:textSize">28sp</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textStyle">bold</item>
        <item name="android:gravity">center</item>
        <item name="android:background">@drawable/bg_pin_box</item>
        <item name="android:inputType">number</item>
        <item name="android:maxLength">1</item>
        <item name="android:importantForAutofill">no</item>
        <item name="android:cursorVisible">false</item>
    </style>
</resources>
