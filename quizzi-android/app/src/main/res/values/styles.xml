<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.Quizzi" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/quizzi_purple</item>
        <item name="colorPrimaryDark">@color/quizzi_purple_dark</item>
        <item name="colorAccent">@color/cta_green</item>
        <item name="android:statusBarColor">@color/bg_primary</item>
        <item name="android:navigationBarColor">@color/bg_primary</item>
        <item name="android:windowBackground">@color/bg_primary</item>
    </style>

    <style name="QuizziButton" parent="Widget.MaterialComponents.Button">
        <item name="cornerRadius">12dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textSize">16sp</item>
        <item name="android:paddingTop">14dp</item>
        <item name="android:paddingBottom">14dp</item>
    </style>

    <style name="QuizziButton.Green" parent="QuizziButton">
        <item name="backgroundTint">@color/cta_green</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <style name="QuizziButton.Purple" parent="QuizziButton">
        <item name="backgroundTint">@color/quizzi_purple</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <style name="AnswerButton" parent="Widget.MaterialComponents.Button">
        <item name="cornerRadius">12dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textSize">18sp</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:fontFamily">sans-serif-bold</item>
        <item name="android:minHeight">80dp</item>
    </style>

    <style name="PinInput">
        <item name="android:textSize">48sp</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textStyle">bold</item>
        <item name="android:gravity">center</item>
        <item name="android:letterSpacing">0.3</item>
        <item name="android:background">@android:color/transparent</item>
        <item name="android:inputType">number</item>
        <item name="android:maxLength">6</item>
    </style>
</resources>
